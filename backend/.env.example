PORT=5000
NODE_ENV=development
JWT_SECRET=change_me_in_production_use_a_long_random_string
JWT_EXPIRES_IN=7d
SUPER_ADMIN_USERNAME=MohanGowri

# --- MongoDB: choose ONE option ---

# Option A: Local MongoDB (development)
# MONGO_URI=mongodb://127.0.0.1:27017/crusher_accounting

# Option B: MongoDB Atlas (recommended for all systems / production)
# Replace USER, PASSWORD, and CLUSTER with your Atlas values.
# URL-encode special characters in the password (@ becomes %40, # becomes %23, etc.)
MONGO_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/crusher_accounting?retryWrites=true&w=majority

# Optional Atlas tuning
# MONGO_SERVER_SELECTION_TIMEOUT_MS=15000
# MONGO_MAX_POOL_SIZE=10

# Allow other PCs/systems to call the API (comma-separated URLs, or * for all origins)
# CORS_ORIGIN=http://192.168.1.50:5000,http://localhost:5173
# CORS_ORIGIN=*

# Used only by npm run migrate:atlas (copy local DB to Atlas once)
# LOCAL_MONGO_URI=mongodb://127.0.0.1:27017/crusher_accounting
# ATLAS_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/crusher_accounting?retryWrites=true&w=majority
